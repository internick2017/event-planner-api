        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Events"
        ],
        "description": "Create a new event. Note: You must first create or get a valid venue ID from the /venues endpoint before creating an event.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string",
                  "example": "Summer Music Festival 2025"
                },
                "description": {
                  "type": "string",
                  "example": "A three-day outdoor music festival featuring local and international artists"
                },
                "date": {
                  "type": "string",
                  "format": "date",
                  "example": "2025-07-15"
                },
                "endDate": {
                  "type": "string",
                  "format": "date",
                  "example": "2025-07-17"
                },
                "time": {
                  "type": "string",
                  "example": "18:00"
                },
                "venueId": {
                  "type": "string",
                  "description": "Valid MongoDB ObjectId of an existing venue. Use GET /venues to find available venue IDs.",
                  "example": "672a1b2c3d4e5f6789012345"
                },
                "category": {
                  "type": "string",
                  "example": "Music"
                },
                "organizer": {
                  "type": "string",
                  "example": "EventCorp Productions"
                },
                "price": {
                  "type": "number",
                  "example": 89.99
                },
                "status": {
                  "type": "string",
                  "enum": ["scheduled", "cancelled", "completed"],
                  "example": "scheduled",
                  "description": "Current status of the event (scheduled, cancelled, or completed)"
                }
              },
              "required": ["title", "description", "date", "time", "venueId", "category", "organizer", "price", "status"]
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
