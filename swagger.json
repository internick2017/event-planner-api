  "definitions": {
    "Event": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "672a1b2c3d4e5f6789012345"
        },
        "title": {
          "type": "string",
          "example": "Summer Music Festival 2025"
        },
        "description": {
          "type": "string",
          "example": "A three-day outdoor music festival featuring local and international artists"
        },
        "date": {
          "type": "string",
          "format": "date",
          "example": "2025-07-15"
        },
        "endDate": {
          "type": "string",
          "format": "date",
          "example": "2025-07-17"
        },
        "time": {
          "type": "string",
          "example": "18:00"
        },
        "venueId": {
          "type": "string",
          "description": "Reference to the venue where this event will take place",
          "example": "672a1b2c3d4e5f6789012346"
        },
        "category": {
          "type": "string",
          "example": "Music"
        },
        "organizer": {
          "type": "string",
          "example": "EventCorp Productions"
        },
        "price": {
          "type": "number",
          "example": 89.99
        },
        "status": {
          "type": "string",
          "enum": ["scheduled", "cancelled", "completed"],
          "example": "scheduled",
          "description": "Current status of the event (scheduled, cancelled, or completed)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "example": "2025-10-11T10:30:00.000Z"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "example": "2025-10-11T14:20:00.000Z"
        }
      }
    },
